#!/bin/bash
# Mux-OS 超頻模式 (Overclock Mode)

# ==============================================================================
# [PROJECT XUM] DUAL-AXIS STATE MACHINE DEFINITION (雙軸狀態機定義)
# ==============================================================================
# 
# AXIS 1: CBR (Chamber State - 物理槍機狀態) -> 位於 CSV 第 2 欄 ($2)
# 描述操作者對實體彈巢的干涉程度。
#   - [Empty] : 預設空值。未被觸碰。
#   - [F]     : Focus (手握住)。執行 `xum slot n` 時寫入。寫入前需全局洗空其他彈巢的 F。
#               * 所有的 `xum input` (資料寫入) 只能在 F 狀態下執行。
#   - [L]     : Locked (上膛解鎖)。執行 `xum set` 時寫入。
#               * `xum fire` 唯一允許擊發的物理狀態。
#   - (解除)  : 執行 `xum unset` 時，清空該欄位 (拔除 F 或 L)。
#
# AXIS 2: STS (Payload Status - 資料健康度狀態) -> 位於 CSV 第 3 欄 ($3)
# 描述該發子彈內部的火藥參數是否完整。
#   - [E]     : Empty (空彈)。預設狀態，無任何參數。
#   - [S]     : Saved (已儲存)。透過 `xum input` 寫入參數後掛上。
#   - [N]     : Not Ready (瑕疵彈)。經過 check 掃描後，發現必要參數不齊全。
#   - [R]     : Ready (完美彈)。經過 check 掃描後，確認可組裝為有效指令。
#               * 允許 L 狀態下強行擊發 E 或 N，作為測試槍管或超載射擊。
# ==============================================================================

# 安全檢測
if [ -z "$MUX_ROOT" ] || [ ! -f "$MUX_ROOT/.mux_state" ]; then
    echo -e "\033[1;35m[SO-xuM: FATAL] Core environment missing. Execution aborted.\033[0m"
    return 1 2>/dev/null || exit 1 
fi

if [ -z "$MUX_ROOT" ]; then export MUX_ROOT="$HOME/mux-os"; fi
export XUM_DB="$MUX_ROOT/xum.csv"

# 超頻系統啟動器 (Overclock System Bootloader)
function _xum_system_boot() {
    _system_lock
    _safe_ui_calc

    # ----------
    # [預留位置]：未來將在此處寫入等級限制鎖
    # ----------
    # 1. 等級系統介入後，等級從L8開始，自動生成的 xum.csv 預設只會有 3 槽的欄位（ Max slot=3 ）
    # 2. 隨着等級增加，槽位+1；當到達 L12 的時候，會全面開放到 8 槽

    # 自動生成基礎
    if [ ! -f "$XUM_DB" ]; then
        echo '"SLOT","CBR","STS","USER","PKG","TARGET","IHEAD","IBODY","URI","MIME","CATE1","CATE2","CATE3","EX1","TRA1","BOO1","EX2","TRA2","BOO2","EX3","TRA3","BOO3","EX4","TRA4","BOO4","EX5","TRA5","BOO5","FLAG"' > "$XUM_DB"
        for i in {1..8}; do
            echo "$i,,\"E\",,,,,,,,,,,,,,,,,,,,,,,,,," >> "$XUM_DB"
        done
    fi

    clear
    _draw_logo "xum"
    _system_check "xum"
    _show_hud "xum"
    _system_unlock
    _bot_say "hello"
}

# 超頻讀取器 (Chamber Reader)
function _xum_neural_read() {
    unset _XUM_SLOT _XUM_CBR _XUM_STS _XUM_USER _XUM_PKG _XUM_TARGET \
          _XUM_IHEAD _XUM_IBODY _XUM_URI _XUM_MIME _XUM_CATE1 _XUM_CATE2 _XUM_CATE3 \
          _XUM_EX1 _XUM_TRA1 _XUM_BOO1 _XUM_EX2 _XUM_TRA2 _XUM_BOO2 \
          _XUM_EX3 _XUM_TRA3 _XUM_BOO3 _XUM_EX4 _XUM_TRA4 _XUM_BOO4 \
          _XUM_EX5 _XUM_TRA5 _XUM_BOO5 _XUM_FLAG

    local target_slot="$1"
    local target_file="${2:-$XUM_DB}"

    if [ ! -f "$target_file" ]; then 
        echo -e "${C_RED} :: ERROR: Chamber database not found.${C_RESET}" >&2
        return 1
    fi

    local raw_data=$(awk -v FPAT='([^,]*)|("[^"]+")' -v slot="$target_slot" '
        NR > 1 { 
            row_slot = $1; gsub(/^"|"$/, "", row_slot); gsub(/^[ \t]+|[ \t]+$/, "", row_slot)
            if (row_slot == slot) {
                print $0
                exit
            }
        }
    ' "$target_file")

    if [ -z "$raw_data" ]; then return 1; fi

    eval $(echo "$raw_data" | awk -v FPAT='([^,]*)|("[^"]+")' '{
        fields[1]="_XUM_SLOT"; fields[2]="_XUM_CBR"; fields[3]="_XUM_STS"; fields[4]="_XUM_USER"
        fields[5]="_XUM_PKG"; fields[6]="_XUM_TARGET"; fields[7]="_XUM_IHEAD"
        fields[8]="_XUM_IBODY"; fields[9]="_XUM_URI"; fields[10]="_XUM_MIME"
        fields[11]="_XUM_CATE1"; fields[12]="_XUM_CATE2"; fields[13]="_XUM_CATE3"
        fields[14]="_XUM_EX1"; fields[15]="_XUM_TRA1"; fields[16]="_XUM_BOO1"
        fields[17]="_XUM_EX2"; fields[18]="_XUM_TRA2"; fields[19]="_XUM_BOO2"
        fields[20]="_XUM_EX3"; fields[21]="_XUM_TRA3"; fields[22]="_XUM_BOO3"
        fields[23]="_XUM_EX4"; fields[24]="_XUM_TRA4"; fields[25]="_XUM_BOO4"
        fields[26]="_XUM_EX5"; fields[27]="_XUM_TRA5"; fields[28]="_XUM_BOO5"
        fields[29]="_XUM_FLAG"

        for (i=1; i<=29; i++) {
            val = $i
            if (val ~ /^".*"$/) { val = substr(val, 2, length(val)-2) }
            gsub(/""/, "\"", val); gsub(/'\''/, "'\''\\'\'''\''", val)
            printf "%s='\''%s'\''; ", fields[i], val
        }
    }')
    
    return 0
}

# 火藥注入器 (Chamber Writer)
function _xum_neural_write() {
    local slot="$1"
    local col_idx="$2"
    local inject_val="$3"
    local tmp_file=$(mktemp)

    if [ "$col_idx" -lt 3 ] || [ "$col_idx" -gt 29 ]; then
        _bot_say "error" "WRITE VIOLATION: Column index $col_idx out of bounds."
        return 1
    fi

    if [ ! -f "$XUM_DB" ]; then
        _bot_say "error" "ARMORY OFFLINE: $XUM_DB not found."
        return 1
    fi

    awk -v FPAT='([^,]*)|("[^"]+")' -v s="$slot" -v c="$col_idx" -v val="$inject_val" '
        BEGIN { OFS="," }
        NR == 1 { print $0; next }
        {
            row_slot = $1
            gsub(/^"|"$/, "", row_slot)
            if (row_slot == s) {
                gsub(/"/, "\"\"", val)
                $c = "\"" val "\""
            }
            print $0
        }
    ' "$XUM_DB" > "$tmp_file" && mv "$tmp_file" "$XUM_DB"
    
    return 0
}

# 輔助函數：修改 CBR 狀態
function _xum_update_cbr() {
    local slot="$1"
    local new_cbr="$2"
    local tmp_file=$(mktemp)
    
    awk -v FPAT='([^,]*)|("[^"]+")' -v s="$slot" -v c="$new_cbr" '
        BEGIN { OFS="," }
        NR == 1 { print $0; next }
        {
            row_slot = $1
            gsub(/^"|"$/, "", row_slot)
            
            if (c == "F" && row_slot != s) {
                if ($2 == "\"F\"") {
                    $2 = ""
                }
            }
            
            # [目標寫入] 處理指定的 Slot
            if (row_slot == s) {
                if (c == "") {
                    $2 = ""
                } else {
                    $2 = "\"" c "\""
                }
            }
            print $0
        }
    ' "$XUM_DB" > "$tmp_file" && mv "$tmp_file" "$XUM_DB"
}

# 輔助函數：修改 STS 狀態
function _xum_update_sts() {
    local slot="$1"
    local new_sts="$2"
    local tmp_file=$(mktemp)
    
    awk -v FPAT='([^,]*)|("[^"]+")' -v s="$slot" -v st="$new_sts" '
        BEGIN { OFS="," }
        NR == 1 { print $0; next }
        {
            row_slot = $1
            gsub(/^"|"$/, "", row_slot)
            
            if (row_slot == s) {
                $3 = "\"" st "\""  # 寫入 E, S, N, R
            }
            print $0
        }
    ' "$XUM_DB" > "$tmp_file" && mv "$tmp_file" "$XUM_DB"
}

# 全域戰術雷達 (Global Chamber Radar)
function _xum_ui_status_all() {
    echo -e "${C_PURPLE} :: Mux-OS Core OC :: CHAMBER RADAR ::${C_RESET}"
    echo -e "${C_BLACK}    ----------${C_RESET}"
    
    awk -v FPAT='([^,]*)|("[^"]+")' \
        -v c_foc="\033[1;33m" -v c_loc="\033[1;31m" \
        -v c_emp="\033[1;30m" -v c_sav="\033[1;33m" \
        -v c_err="\033[1;31m" -v c_rdy="\033[1;32m" \
        -v c_rst="\033[0m" -v c_id="\033[1;36m" '
        NR > 1 {
            slot = $1; gsub(/^"|"$/, "", slot); gsub(/^[ \t]+|[ \t]+$/, "", slot)
            cbr = $2; gsub(/^"|"$/, "", cbr); gsub(/^[ \t]+|[ \t]+$/, "", cbr)
            sts = $3; gsub(/^"|"$/, "", sts); gsub(/^[ \t]+|[ \t]+$/, "", sts)
            pkg = $5; gsub(/^"|"$/, "", pkg);
            uri = $9; gsub(/^"|"$/, "", uri); 
            
            if (slot == "") next;

            # CBR (Chamber) 實體狀態
            cbr_disp = "      "
            if (cbr == "F") cbr_disp = c_foc "[FOC] " c_rst
            if (cbr == "L") cbr_disp = c_loc "[LOCK]" c_rst

            # STS (Payload) 參數健康度
            sts_disp = c_emp "[E]" c_rst
            if (sts == "S") sts_disp = c_sav "[S]" c_rst
            if (sts == "N") sts_disp = c_err "[N]" c_rst
            if (sts == "R") sts_disp = c_rdy "[R]" c_rst
            
            # Payload 內容預覽
            preview = ""
            if (pkg != "") preview = pkg
            else if (uri != "") preview = uri
            else preview = "---"
            
            if (length(preview) > 22) preview = substr(preview, 1, 19) "..."

            printf "   SLOT %s | %s | %s | %s%s%s\n", slot, cbr_disp, sts_disp, c_id, preview, c_rst
        }
    ' "$XUM_DB"
    
    echo -e "${C_BLACK}    ----------${C_RESET}"
}

# 戰術狀態面板 (Tactical Status Panel)
function _xum_ui_status_panel() {
    local slot="${1:-$XUM_CURRENT_SLOT}"
    
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi

    _xum_neural_read "$slot"
    if [ $? -ne 0 ]; then
        _bot_say "error" "FAILED TO READ CHAMBER [$slot]."
        return 1
    fi

    local cbr_disp="${_XUM_CBR:-Empty}"
    if [ "$_XUM_CBR" == "F" ]; then 
        cbr_disp="\033[1;33m[Focused]\033[0m"
    elif [ "$_XUM_CBR" == "L" ]; then 
        cbr_disp="\033[1;31m[Locked]\033[0m"
    fi

    # 狀態轉換
    local sts_disp="${_XUM_STS}"
    case "$_XUM_STS" in
        "E"|"") sts_disp="\033[1;37m[Empty]\033[0m" ;;      # 高亮白
        "S")    sts_disp="\033[1;33m[Saved]\033[0m" ;;      # 黃色
        "N")    sts_disp="\033[1;31m[Not Ready]\033[0m" ;;  # 紅色
        "R")    sts_disp="\033[1;32m[Ready]\033[0m" ;;      # 綠色
        *)      sts_disp="\033[1;37m[${_XUM_STS}]\033[0m" ;;
    esac

    echo -e "${C_PURPLE} :: Mux-OS Core OC Status ::${C_RESET}"
    echo -e "${C_BLACK}  ----------${C_RESET}"
    echo -e "   CHAMBER : ${C_TAVIOLET}[$slot]${C_RESET}"
    echo -e "   STATUS  : $cbr_disp"
    echo -e "   PAYLOAD : $sts_disp"
    echo -e "${C_BLACK}  ----------${C_RESET}"
    
    # 依序印出實體參數
    [ -n "$_XUM_USER" ]   && printf "   %-7s : \033[1;36m%s\033[0m\n" "USER" "$_XUM_USER"
    [ -n "$_XUM_PKG" ]    && printf "   %-7s : \033[1;36m%s\033[0m\n" "PKG" "$_XUM_PKG"
    [ -n "$_XUM_TARGET" ] && printf "   %-7s : \033[1;36m%s\033[0m\n" "TARGET" "$_XUM_TARGET"
    
    local intent="${_XUM_IHEAD}${_XUM_IBODY}"
    [ -n "$intent" ]      && printf "   %-7s : \033[1;36m%s\033[0m\n" "INTENT" "$intent"
    
    [ -n "$_XUM_URI" ]    && printf "   %-7s : \033[1;36m%s\033[0m\n" "URI" "$_XUM_URI"
    [ -n "$_XUM_MIME" ]   && printf "   %-7s : \033[1;36m%s\033[0m\n" "MIME" "$_XUM_MIME"
    
    local prefix_cate="android.intent.category."
    [ -n "$_XUM_CATE1" ]  && printf "   %-7s : \033[1;36m%s\033[0m\n" "CATE1" "${prefix_cate}${_XUM_CATE1}"
    [ -n "$_XUM_CATE2" ]  && printf "   %-7s : \033[1;36m%s\033[0m\n" "CATE2" "${prefix_cate}${_XUM_CATE2}"
    [ -n "$_XUM_CATE3" ]  && printf "   %-7s : \033[1;36m%s\033[0m\n" "CATE3" "${prefix_cate}${_XUM_CATE3}"
    
    for i in {1..5}; do
        local ex_var="_XUM_EX${i}"; local tra_var="_XUM_TRA${i}"; local boo_var="_XUM_BOO${i}"
        if [ -n "${!ex_var}" ]; then
            printf "   %-7s : \033[1;36m%s \"%s\" \"%s\"\033[0m\n" "EXTRA$i" "${!ex_var}" "${!tra_var}" "${!boo_var}"
        fi
    done
    
    [ -n "$_XUM_FLAG" ]   && printf "   %-7s : \033[1;36m%s\033[0m\n" "FLAG" "$_XUM_FLAG"
}

# 選擇並握住彈巢 (Slot Focus -> CBR: F)
function _xum_cmd_slot() {
    local slot="$1"
    if [[ ! "$slot" =~ ^[1-8]$ ]]; then
        _bot_say "error" "INVALID CHAMBER: $slot. Provide 1-8."
        return 1
    fi

    _xum_update_cbr "$slot" "F"
    export XUM_CURRENT_SLOT="$slot"

    _xum_ui_status_panel "$slot"
}

# 參數掃描器 (Payload Scanner & STS Validator)
function _xum_cmd_check() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi

    # 1. 讀取最新記憶體
    _xum_neural_read "$slot"

    # 2. 絕對物理防呆：只能在 CBR 為 F 時執行
    if [ "$_XUM_CBR" != "F" ]; then
        local current_cbr="${_XUM_CBR:-EMPTY}"
        _bot_say "error" "SCAN DENIED. Chamber must be focused (F). Current CBR: [$current_cbr]."
        return 1
    fi

    echo -e "${C_TAVIOLET} :: CHAMBER [$slot] PAYLOAD SCANNING... ::${C_RESET}"

    # 3. 判斷是否為「絕對空彈 (E)」
    local action="${_XUM_IHEAD}${_XUM_IBODY}"
    local is_empty=true
    
    # 掃描所有有效負載欄位
    local check_fields=("$action" "$_XUM_PKG" "$_XUM_TARGET" "$_XUM_URI" "$_XUM_MIME" "$_XUM_CATE1" "$_XUM_CATE2" "$_XUM_CATE3" "$_XUM_FLAG")
    for val in "${check_fields[@]}"; do
        if [ -n "$val" ]; then is_empty=false; break; fi
    done
    for i in {1..5}; do
        local ex="_XUM_EX${i}"; local tra="_XUM_TRA${i}"; local boo="_XUM_BOO${i}"
        if [ -n "${!ex}" ] || [ -n "${!tra}" ] || [ -n "${!boo}" ]; then is_empty=false; break; fi
    done

    # 若為空彈，維持 E 並提早結束
    if [ "$is_empty" == true ]; then
        _xum_update_sts "$slot" "E"
        echo -e "${C_BLACK}    ›› No payload detected. Chamber is empty.${C_RESET}"
        _bot_say "warn" "SCAN COMPLETE. STS REMAINS [E]."
        return 0
    fi

    # 4. 瑕疵判定邏輯 (N vs R)
    local is_defective=false
    local defective_reason=""
    local has_core=false

    [ -n "$action" ] || [ -n "$_XUM_URI" ] || [ -n "$_XUM_PKG" ] && has_core=true

    # 規則 A: 沒有核心路由
    if [ "$has_core" == false ]; then
        is_defective=true
        defective_reason="Missing core routing (PKG, ACTION, or URI)."
    fi

    # 規則 B: 有 TARGET 但沒有 PKG
    if [ -n "$_XUM_TARGET" ] && [ -z "$_XUM_PKG" ]; then
        is_defective=true
        defective_reason="TARGET specified but PKG is missing."
    fi

    # 規則 C: EX 擴充參數缺少 Key (TRA)
    for i in {1..5}; do
        local ex_var="_XUM_EX${i}"; local tra_var="_XUM_TRA${i}"
        if [ -n "${!ex_var}" ] && [ -z "${!tra_var}" ]; then
            is_defective=true
            defective_reason="EX$i specified but missing Key (TRA$i)."
            break
        fi
    done

    # 5. 寫入狀態與輸出報告
    if [ "$is_defective" == true ]; then
        _xum_update_sts "$slot" "N"
        echo -e "${C_RED}    ›› Defect detected : $defective_reason${C_RESET}"
        _bot_say "error" "PAYLOAD DEFECTIVE. STS UPDATED TO [N]."
    else
        _xum_update_sts "$slot" "R"
        echo -e "${C_GREEN}    ›› All structural checks passed.${C_RESET}"
        _bot_say "success" "PAYLOAD VERIFIED. STS UPDATED TO [R]."
    fi
}

# 核心彈藥匯入注射器 (Core Payload Injector)
function _xum_cmd_import() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi

    _xum_neural_read "$slot"
    if [ "$_XUM_CBR" != "F" ]; then
        local current_cbr="${_XUM_CBR:-EMPTY}"
        _bot_say "error" "IMPORT DENIED. Chamber must be focused (F). Current: [$current_cbr]."
        return 1
    fi

    # 掃描 CSV 核心指令
    local border_color="90"
    local raw_list=$(awk -v FPAT='([^,]*)|("[^"]+")' '
        FNR > 1 && !/^#/ {
            cmd = $5; gsub(/^"|"$/, "", cmd); gsub(/^[ \t]+|[ \t]+$/, "", cmd)
            sub_cmd = $6; gsub(/^"|"$/, "", sub_cmd); gsub(/^[ \t]+|[ \t]+$/, "", sub_cmd)
            
            if (cmd != "") {
                n = split(FILENAME, path_parts, "/")
                file_name = path_parts[n]
                sub(/\.csv$/, "", file_name)
                
                if (sub_cmd != "") {
                    printf "%s|%s|\033[1;36m%-9s\033[0m %-9s \033[1;30m%s\033[0m\n", cmd, sub_cmd, cmd, sub_cmd, file_name
                } else {
                    printf "%s|%s|\033[1;36m%-9s\033[0m %-9s \033[1;30m%s\033[0m\n", cmd, "", cmd, "", file_name
                }
            }
        }
    ' "$SYSTEM_MOD" "$VENDOR_MOD" "$APP_MOD" 2>/dev/null)

    if [ -z "$raw_list" ]; then
        _bot_say "error" "Core Database is empty or inaccessible."
        return 1
    fi

    local total_nodes=$(echo -e "$raw_list" | wc -l)

    local selection=$(echo -e "$raw_list" | fzf --ansi \
        --delimiter='\|' --with-nth=3.. \
        --height=15 \
        --layout=reverse \
        --border-label=" :: CORE PAYLOAD IMPORT :: " \
        --border=bottom \
        --prompt=" :: Select Tatget › " \
        --header=" :: Enter to Select, Esc to Return ::" \
        --info=hidden \
        --pointer="››" \
        --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
        --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color,header:240 \
        --bind="resize:clear-screen"
    )

    if [ -z "$selection" ]; then
        echo -e "${C_GRAY}    ›› Import aborted.${C_RESET}"
        return 0
    fi

    # 萃取隱藏的防呆指令參數
    local i_cmd=$(echo "$selection" | cut -d'|' -f1)
    local i_sub=$(echo "$selection" | cut -d'|' -f2)

    local node_disp="$i_cmd"
    [ -n "$i_sub" ] && node_disp="$i_cmd $i_sub"

    echo -e "${C_GRAY}    ›› Extracting Core Node [$node_disp]...${C_RESET}"
    
    # 呼叫核心神經元讀取並寫入
    _mux_neural_data "$i_cmd" "$i_sub"
    if [ $? -eq 0 ]; then
        # 綁定當前駕駛員
        _xum_neural_write "$slot" 4 ""
        
        # 寫入核心參數
        _xum_neural_write "$slot" 5 "$_VAL_PKG"
        _xum_neural_write "$slot" 6 "$_VAL_TARGET"
        _xum_neural_write "$slot" 7 "$_VAL_IHEAD"
        _xum_neural_write "$slot" 8 "$_VAL_IBODY"
        
        # 處理 URI 轉譯
        local final_uri="$_VAL_URI"
        # 1. 處理 ENGINE (原有的 $__GO_TARGET)
        if [[ "$final_uri" == *"\$__GO_TARGET"* ]] && [ -n "$_VAL_ENGINE" ]; then
            local expanded_engine=$(eval echo "$_VAL_ENGINE")
            final_uri="${final_uri//\$__GO_TARGET/$expanded_engine}"
        fi

        # 2. 轉譯 $SEARCH_* 變數 (讓工作檯能看見完整網址)
        if [[ "$final_uri" == *"\$SEARCH_"* ]]; then
            final_uri=$(eval echo "$final_uri")
        fi

        # 3. 掃描 $query 引信並在匯入當下要求填充
        local q_input=""
        if [[ "$final_uri" == *"\$query"* ]] || [[ "$_VAL_EXTRA" == *"\$query"* ]] || [[ "$_VAL_BOOLEN" == *"\$query"* ]]; then
            echo -e "\n\033[1;33m :: DYNAMIC PAYLOAD DETECTED ::\033[0m"
            echo -e "\033[1;30m    ›› Core node requires a '\$query' variable.\033[0m"
            read -e -p "$(echo -e "\033[38;5;90m :: INPUT \$query › \033[0m")" q_input
            
            # 實體化替換 (URI 處理空格轉 + 號，其餘保持原樣)
            local safe_q="${q_input// /+}"
            final_uri="${final_uri//\$query/$safe_q}"
            _VAL_EXTRA="${_VAL_EXTRA//\$query/$q_input}"
            _VAL_BOOLEN="${_VAL_BOOLEN//\$query/$q_input}"
        fi
        
        # 執行原子寫入
        _xum_neural_write "$slot" 9 "$final_uri"
        _xum_neural_write "$slot" 10 "$_VAL_MIME"
        
        # 對接 Core 神經連結參數
        _xum_neural_write "$slot" 11 "$_VAL_CATE"
        _xum_neural_write "$slot" 12 "" 
        _xum_neural_write "$slot" 13 ""
        _xum_neural_write "$slot" 14 "$_VAL_EX"
        _xum_neural_write "$slot" 15 "$_VAL_EXTRA"
        _xum_neural_write "$slot" 16 "$_VAL_BOOLEN"
        
        for c in {17..28}; do _xum_neural_write "$slot" "$c" ""; done
        
        _xum_neural_write "$slot" 29 "$_VAL_FLAG"
        
        # 狀態標記轉換
        _xum_update_sts "$slot" "S"
        _bot_say "success" "Core Payload [\033[1;36m$i_cmd $i_sub\033[0m] Injected to Chamber $slot."
        
        _xum_ui_status_panel "$slot"
    else
        _bot_say "error" "Import Failed: Core Node [$i_cmd $i_sub] Not Found."
        return 1
    fi
}

# 互動式裝填工作檯 (Interactive Payload Workbench)
function _xum_cmd_input() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi

    _xum_neural_read "$slot"
    if [ "$_XUM_CBR" != "F" ]; then
        local current_cbr="${_XUM_CBR:-EMPTY}"
        _bot_say "error" "WORKBENCH LOCKED. Chamber must be focused (F). Current: [$current_cbr]."
        return 1
    fi

    local border_color="90"

    # 主要工作臺 - Main Workbench
    while true; do
        _xum_neural_read "$slot"
        
        # 主選單
        local menu_items=""
        menu_items+="\033[1;37mUSER\033[0m\t\033[1;36m${_XUM_USER}\033[0m\n"
        menu_items+="\033[1;37mPKG\033[0m\t\033[1;36m${_XUM_PKG}\033[0m\n"
        menu_items+="\033[1;37mTARGET\033[0m\t\033[1;36m${_XUM_TARGET}\033[0m\n"
        
        local intent_disp="${_XUM_IHEAD}${_XUM_IBODY}"
        menu_items+="\033[1;37mINTENT\033[0m\t\033[1;36m${intent_disp}\033[0m\n"
        
        menu_items+="\033[1;37mURI\033[0m\t\033[1;36m${_XUM_URI}\033[0m\n"
        menu_items+="\033[1;37mMIME\033[0m\t\033[1;36m${_XUM_MIME}\033[0m\n"
        
        # 動態 Category 參數注入
        local prefix_cate="android.intent.category."
        local disp_cate1=""; [ -n "$_XUM_CATE1" ] && disp_cate1="${prefix_cate}${_XUM_CATE1}"
        local disp_cate2=""; [ -n "$_XUM_CATE2" ] && disp_cate2="${prefix_cate}${_XUM_CATE2}"
        local disp_cate3=""; [ -n "$_XUM_CATE3" ] && disp_cate3="${prefix_cate}${_XUM_CATE3}"

        menu_items+="\033[1;37mCATE1\033[0m\t\033[1;36m${disp_cate1}\033[0m\n"
        if [ -n "$_XUM_CATE1" ] || [ -n "$_XUM_CATE2" ]; then
            menu_items+="\033[1;37mCATE2\033[0m\t\033[1;36m${disp_cate2}\033[0m\n"
        fi
        if [ -n "$_XUM_CATE2" ] || [ -n "$_XUM_CATE3" ]; then
            menu_items+="\033[1;37mCATE3\033[0m\t\033[1;36m${disp_cate3}\033[0m\n"
        fi
        
        # 動態 Extra 參數注入
        for i in {1..5}; do
            local ex_var="_XUM_EX${i}"; local tra_var="_XUM_TRA${i}"; local boo_var="_XUM_BOO${i}"
            local ex_val="${!ex_var}"; local tra_val="${!tra_var}"; local boo_val="${!boo_var}"
            
            local disp_val=""
            [ -n "$ex_val" ] && disp_val+="${ex_val} "
            [ -n "$tra_val" ] && disp_val+="\"${tra_val}\" "
            [ -n "$boo_val" ] && disp_val+="\"${boo_val}\""
            
            menu_items+="\033[1;37mEXTRA${i}\033[0m\t\033[1;36m${disp_val}\033[0m\n"
            
            if [ -z "$ex_val" ] && [ -z "$tra_val" ] && [ -z "$boo_val" ]; then
                break
            fi
        done
        
        menu_items+="\033[1;37mFLAG\033[0m\t\033[1;36m${_XUM_FLAG}\033[0m\n"
        menu_items+="\033[1;30m----------\033[0m\n"
        menu_items+="\033[1;32m[Confirm]\033[0m"

        local total_main=$(echo -e "$menu_items" | grep -c "^")
        local selection=$(echo -e "$menu_items" | fzf --ansi \
            --height=16 \
            --layout=reverse \
            --border-label=" :: CHAMBER [$slot] WORKBENCH :: " \
            --border=bottom \
            --tabstop=10 \
            --prompt=" :: SELECT FIELD › " \
            --header=" :: Enter to Select, Esc to Return ::" \
            --info=hidden \
            --pointer="››" \
            --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
            --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color,header:240 \
            --bind="resize:clear-screen"
        )
        
        if [ -z "$selection" ]; then 
            echo -e "${C_GRAY}    ›› Workbench closed. Initiating safety scan...${C_RESET}"
            _xum_cmd_check
            break
        fi 
        
        # 清洗色碼
        local field=$(echo "$selection" | sed $'s/\033\\[[0-9;]*m//g' | awk '{print $1}')
        
        if [ "$field" == "[Confirm]" ]; then
            echo -e "${C_GRAY}    ›› Workbench closed. Initiating safety scan...${C_RESET}"
            _xum_cmd_check
            break
        fi
        if [[ "$field" == *"----------"* ]]; then continue; fi

        # Intent 擴充
        if [ "$field" == "INTENT" ]; then
            while true; do
                _xum_neural_read "$slot"
                local sub_menu=""
                sub_menu+="\033[1;37mIHEAD\033[0m\t\033[1;36m${_XUM_IHEAD}\033[0m\n"
                sub_menu+="\033[1;37mIBODY\033[0m\t\033[1;36m${_XUM_IBODY}\033[0m\n"
                sub_menu+="\033[1;30m----------\033[0m\n"
                sub_menu+="\033[1;32m[Confirm]\033[0m"

                local sub_sel=$(echo -e "$sub_menu" | fzf --ansi \
                    --height=8 \
                    --layout=reverse \
                    --border-label=" :: INTENT CONFIG :: " \
                    --border=bottom \
                    --tabstop=10 \
                    --prompt=" :: MODIFY › " \
                    --header=" :: Enter to Select, Esc to Return ::" \
                    --info=hidden \
                    --pointer="››" \
                    --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
                    --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color \
                    --bind="resize:clear-screen"
                )
                
                if [ -z "$sub_sel" ]; then break; fi
                
                local sub_field=$(echo "$sub_sel" | sed $'s/\033\\[[0-9;]*m//g' | awk '{print $1}')
                
                if [ "$sub_field" == "[Confirm]" ]; then break; fi
                if [[ "$sub_field" == *"----------"* ]]; then continue; fi
                
                local intent_opts=""
                local intent_col=""
                
                if [ "$sub_field" == "IHEAD" ]; then
                    local ex_ihead=$(awk -F',' 'FNR>1 {gsub(/"/,"",$12); if($12!="") print $12}' "$MUX_ROOT"/{app,system,vendor}.csv 2>/dev/null | sort -u)
                    [ -z "$ex_ihead" ] && ex_ihead="android.intent.action\nandroid.settings"
                    intent_opts=$(echo -e "$ex_ihead" | awk 'NF {printf "%s\\n", $0}')
                    intent_col=7
                elif [ "$sub_field" == "IBODY" ]; then
                    local ex_ibody=$(awk -F',' 'FNR>1 {gsub(/"/,"",$13); if($13!="") print $13}' "$MUX_ROOT"/{app,system,vendor}.csv 2>/dev/null)
                    local std_ibody=".MAIN\n.VIEW\n.SEARCH\n.SEND\n.DIAL\n.CALL\n.WEB_SEARCH\n.VOICE_COMMAND\n.SET_ALARM\n.SET_TIMER\n.SHOW_ALARMS\n.WIFI_SETTINGS\n.BLUETOOTH_SETTINGS\n.DISPLAY_SETTINGS\n.DATE_SETTINGS"
                    intent_opts=$(echo -e "${ex_ibody}\n${std_ibody}" | sort -u | awk 'NF {printf "%s\\n", $0}')
                    intent_col=8
                fi
                
                intent_opts+="\n\033[1;33m[Custom]\033[0m\n\033[1;31m[Clear]\033[0m"
                
                local final_sel=$(echo -e "$intent_opts" | fzf --ansi \
                    --height=12 \
                    --layout=reverse \
                    --border-label=" :: [$sub_field] PAYLOAD :: " \
                    --border=bottom \
                    --prompt=" :: INPUT › " \
                    --header=" :: Enter to Select, Esc to Return ::" \
                    --info=hidden \
                    --pointer="››" \
                    --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
                    --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color \
                    --bind="resize:clear-screen"
                )
                
                if [ -z "$final_sel" ]; then continue; fi
                
                local final_val_clean=$(echo "$final_sel" | sed $'s/\033\\[[0-9;]*m//g')
                local final_val="$final_val_clean"
                
                if [ "$final_val_clean" == "[Clear]" ]; then 
                    final_val=""
                elif [ "$final_val_clean" == "[Custom]" ]; then
                    local current_val=""
                    [ "$sub_field" == "IHEAD" ] && current_val="$_XUM_IHEAD"
                    [ "$sub_field" == "IBODY" ] && current_val="$_XUM_IBODY"
                    
                    # 熱載入現有變數至輸入框
                    read -e -p "$(echo -e "\033[38;5;${border_color}m :: [$sub_field] CUSTOM INPUT › \033[0m")" -i "$current_val" final_val
                fi
                
                _xum_neural_write "$slot" "$intent_col" "$final_val"
                _xum_update_sts "$slot" "S"
            done
            continue
        fi

        # Extra 擴充
        if [[ "$field" =~ ^EXTRA([1-5])$ ]]; then
            local n="${BASH_REMATCH[1]}"
            while true; do
                _xum_neural_read "$slot"
                local ex_var="_XUM_EX${n}"; local tra_var="_XUM_TRA${n}"; local boo_var="_XUM_BOO${n}"
                
                local sub_menu=""
                sub_menu+="\033[1;37mEX${n}\033[0m\t\033[1;36m${!ex_var}\033[0m\n"
                sub_menu+="\033[1;37mTRA${n}\033[0m\t\033[1;36m${!tra_var}\033[0m\n"
                sub_menu+="\033[1;37mBOO${n}\033[0m\t\033[1;36m${!boo_var}\033[0m\n"
                sub_menu+="\033[1;30m----------\033[0m\n"
                sub_menu+="\033[1;32m[Confirm]\033[0m"

                local sub_sel=$(echo -e "$sub_menu" | fzf --ansi \
                    --height=10 \
                    --layout=reverse \
                    --border-label=" :: [EXTRA $n] CONFIG :: " \
                    --border=bottom \
                    --tabstop=10 \
                    --prompt=" :: MODIFY › " \
                    --header=" :: Enter to Select, Esc to Return ::" \
                    --info=hidden \
                    --pointer="››" \
                    --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
                    --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color \
                    --bind="resize:clear-screen"
                )
                if [ -z "$sub_sel" ]; then break; fi
                
                local sub_field=$(echo "$sub_sel" | sed $'s/\033\\[[0-9;]*m//g' | awk '{print $1}')
                
                if [ "$sub_field" == "[Confirm]" ]; then break; fi 
                if [[ "$sub_field" == *"----------"* ]]; then continue; fi
                
                local ex_opts=""
                local ex_col=""
                if [ "$sub_field" == "EX${n}" ]; then
                    ex_opts="--e\n--es\n--ez\n--ei\n--ef\n--el\n--eu\n--ena\n--esa\n--esb\n--eia\n"
                    ex_col=$(( 14 + (n - 1) * 3 ))
                elif [ "$sub_field" == "TRA${n}" ]; then
                    ex_opts="android.intent.extra.TEXT\nandroid.intent.extra.SUBJECT\nandroid.intent.extra.TITLE\nandroid.intent.extra.EMAIL\nandroid.intent.extra.CC\nandroid.intent.extra.BCC\nandroid.intent.extra.STREAM\nandroid.intent.extra.PHONE_NUMBER\nquery\nandroid.intent.extra.alarm.MESSAGE\nandroid.intent.extra.alarm.HOUR\nandroid.intent.extra.alarm.MINUTES\nandroid.intent.extra.alarm.SKIP_UI\nandroid.intent.extra.alarm.LENGTH\n"
                    ex_col=$(( 15 + (n - 1) * 3 ))
                elif [ "$sub_field" == "BOO${n}" ]; then
                    ex_opts="true\nfalse\n"
                    ex_col=$(( 16 + (n - 1) * 3 ))
                fi
                ex_opts+="\033[1;33m[Custom]\033[0m\n\033[1;31m[Clear]\033[0m"
                
                local final_sel=$(echo -e "$ex_opts" | fzf --ansi \
                    --height=10 \
                    --layout=reverse \
                    --border-label=" :: [$sub_field] PAYLOAD :: " \
                    --border=bottom \
                    --prompt=" :: INPUT › " \
                    --header=" :: Enter to Select, Esc to Return ::" \
                    --info=hidden \
                    --pointer="››" \
                    --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
                    --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color \
                    --bind="resize:clear-screen"
                )
                if [ -z "$final_sel" ]; then continue; fi
                
                local final_val_clean=$(echo "$final_sel" | sed $'s/\033\\[[0-9;]*m//g')
                local final_val="$final_val_clean"
                
                if [ "$final_val_clean" == "[Clear]" ]; then 
                    final_val=""
                elif [ "$final_val_clean" == "[Custom]" ]; then
                    local current_val=""
                    # 利用變數展開抓取動態變數
                    [ "$sub_field" == "EX${n}" ] && current_val="${!ex_var}"
                    [ "$sub_field" == "TRA${n}" ] && current_val="${!tra_var}"
                    [ "$sub_field" == "BOO${n}" ] && current_val="${!boo_var}"
                    
                    # 熱重載探針
                    read -e -p "$(echo -e "\033[38;5;${border_color}m :: [$sub_field] CUSTOM INPUT › \033[0m")" -i "$current_val" final_val
                fi
                
                _xum_neural_write "$slot" "$ex_col" "$final_val"
                _xum_update_sts "$slot" "S"
            done
            continue
        fi

        # 常規欄位參數
        local sub_opts=""
        local col_idx=""
        case "$field" in
            "USER")
                sub_opts="0\ncurrent\nall\n10"
                col_idx=4
                ;;
            "PKG")
                sub_opts="\033[1;36m[Import from Core]\033[0m\n\033[1;32m[Run 'apklist']\033[0m"
                col_idx=5 
                ;;
            "TARGET")
                sub_opts=".MainActivity\n.HomeActivity\nnull"
                col_idx=6
                ;;
            "URI")    
                local uri_list=$(grep "^export SEARCH_" "$MUX_ROOT/core.sh" | awk -F'=' '{gsub(/^export /, ""); print "$" $1}')
                sub_opts=$(echo -e "${uri_list}" | awk 'NF {printf "%s\\n", $0}')
                col_idx=9
                ;;
            "MIME")   
                sub_opts="*/*\n"
                # 文本與代碼
                sub_opts+="text/plain\ntext/html\ntext/xml\ntext/csv\ntext/x-vcard"
                # 圖片
                sub_opts+="image/*\nimage/jpeg\nimage/png\nimage/gif\nimage/webp\nimage/svg+xml"
                # 影片
                sub_opts+="video/*\nvideo/mp4\nvideo/x-matroska\nvideo/webm"
                # 音訊
                sub_opts+="audio/*\naudio/mpeg\naudio/mp4\naudio/ogg\naudio/wav"
                # 應用程式與封裝檔
                sub_opts+="application/vnd.android.package-archive" # APK 安裝包
                sub_opts+="application/pdf\napplication/zip\napplication/json"
                # 微軟 Office 文件
                sub_opts+="application/msword\napplication/vnd.openxmlformats-officedocument.wordprocessingml.document" # Word
                sub_opts+="application/vnd.ms-excel\napplication/vnd.openxmlformats-officedocument.spreadsheetml.sheet" # Excel
                sub_opts+="application/vnd.ms-powerpoint\napplication/vnd.openxmlformats-officedocument.presentationml.presentation" # PPT
                col_idx=10 
                ;;
            "CATE1"|"CATE2"|"CATE3")  
                # 核心與系統層級 (Core & System)
                sub_opts="DEFAULT\nBROWSABLE\nLAUNCHER\nHOME\nINFO\nOPENABLE\nTYPED_OPENABLE\nPREFERENCE\nTAB\nALTERNATIVE\nSELECTED_ALTERNATIVE\nTEST\nCAR_DOCK\nDESK_DOCK\nLEANBACK_LAUNCHER"
                # 應用程式類型 (App Types - Primary)
                sub_opts+="APP_MARKET\nAPP_BROWSER\nAPP_CALCULATOR\nAPP_CALENDAR\nAPP_CONTACTS\nAPP_EMAIL\nAPP_GALLERY\nAPP_MAPS\nAPP_MESSAGING\nAPP_MUSIC\nAPP_SETTINGS\nAPP_FILES\nAPP_CAMERA\nAPP_CLOCK\nAPP_WEATHER\nAPP_NOTES\nAPP_VOICE_RECORDER"
                # 應用程式類型 (App Types - Extended)
                sub_opts+="APP_NEWS\nAPP_PRODUCTIVITY\nAPP_SOCIAL\nAPP_GAMES\nAPP_BOOKS\nAPP_VIDEO\nAPP_PODCASTS\nAPP_HEALTH_FITNESS\nAPP_TRAVEL_LOCAL\nAPP_FINANCE\nAPP_SHOPPING\nAPP_FOOD_DRINK\nAPP_ENTERTAINMENT\nAPP_LIFESTYLE\nAPP_EDUCATION\nAPP_BUSINESS\nAPP_TOOLS\nAPP_COMMUNICATION\nAPP_PERSONALIZATION\nAPP_AUTO_AND_VEHICLES\nAPP_BEAUTY\nAPP_COMICS\nAPP_DATING\nAPP_EVENTS\nAPP_HOUSE_HOME\nAPP_MEDICAL\nAPP_PARENTING\nAPP_PHOTOGRAPHY\nAPP_SPORTS"
                
                if [ "$field" == "CATE1" ]; then col_idx=11
                elif [ "$field" == "CATE2" ]; then col_idx=12
                elif [ "$field" == "CATE3" ]; then col_idx=13
                fi
                ;;
            "FLAG")
                sub_opts="0x10000000\n0x04000000\n0x20000000\n0x08000000\n0x00000001\n0x00000002\n--activity-clear-top\n--activity-single-top\n--activity-no-history\n--activity-previous-is-top\n--activity-clear-task"
                col_idx=29
                ;;
            *) continue ;;
        esac
        
        sub_opts+="\n\033[1;33m[Custom]\033[0m\n\033[1;31m[Clear]\033[0m"
        local total_sub=$(echo -e "$sub_opts" | grep -c "^")
        
        local sub_sel=$(echo -e "$sub_opts" | fzf --ansi \
            --height=12 \
            --layout=reverse \
            --border-label=" :: [$field] PAYLOAD :: " \
            --header=" :: Enter to Select, Esc to Return ::" \
            --border=bottom \
            --prompt=" :: INPUT › " \
            --header=" :: Nodes: [$total_sub] ::" \
            --info=hidden \
            --pointer="››" \
            --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
            --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color,header:240 \
            --bind="resize:clear-screen"
        )
        if [ -z "$sub_sel" ]; then continue; fi
        
        local final_val_clean=$(echo "$sub_sel" | sed $'s/\033\\[[0-9;]*m//g')
        local final_val="$final_val_clean"
        
        if [ "$final_val_clean" == "[Clear]" ]; then 
            final_val=""
        elif [ "$final_val_clean" == "[Custom]" ]; then
            local current_val=""
            case "$field" in
                "USER") current_val="$_XUM_USER" ;;
                "PKG") current_val="$_XUM_PKG" ;;
                "TARGET") current_val="$_XUM_TARGET" ;;
                "URI") current_val="$_XUM_URI" ;;
                "MIME") current_val="$_XUM_MIME" ;;
                "CATE1") current_val="$_XUM_CATE1" ;;
                "CATE2") current_val="$_XUM_CATE2" ;;
                "CATE3") current_val="$_XUM_CATE3" ;;
                "FLAG") current_val="$_XUM_FLAG" ;;
            esac
            read -e -p "$(echo -e "\033[38;5;${border_color}m :: [$field] CUSTOM INPUT › \033[0m")" -i "$current_val" final_val
            
        # 核心節點 PKG 萃取
        elif [ "$final_val_clean" == "[Import from Core]" ]; then
            local raw_list=$(awk -v FPAT='([^,]*)|("[^"]+")' '
                FNR > 1 && !/^#/ {
                    cmd = $5; gsub(/^"|"$/, "", cmd); gsub(/^[ \t]+|[ \t]+$/, "", cmd)
                    sub_cmd = $6; gsub(/^"|"$/, "", sub_cmd); gsub(/^[ \t]+|[ \t]+$/, "", sub_cmd)
                    if (cmd != "") {
                        n = split(FILENAME, path_parts, "/")
                        file_name = path_parts[n]
                        sub(/\.csv$/, "", file_name)
                        if (sub_cmd != "") {
                            printf "%s|%s|\033[1;36m%-9s\033[0m %-9s \033[1;30m%s\033[0m\n", cmd, sub_cmd, cmd, sub_cmd, file_name
                        } else {
                            printf "%s|%s|\033[1;36m%-9s\033[0m %-9s \033[1;30m%s\033[0m\n", cmd, "", cmd, "", file_name
                        }
                    }
                }
            ' "$SYSTEM_MOD" "$VENDOR_MOD" "$APP_MOD" 2>/dev/null)

            local selection=$(echo -e "$raw_list" | fzf --ansi \
                --delimiter='\|' \
                --with-nth=3.. \
                --height=15 \
                --layout=reverse \
                --header=" :: Enter to Select, Esc to Return ::" \
                --border-label=" :: CORE PKG EXTRACTOR :: " \
                --border=bottom \
                --prompt=" :: Select Node › " \
                --pointer="››" \
                --color=fg:white,bg:-1,hl:240,fg+:white,bg+:235,hl+:240 \
                --color=info:240,prompt:$border_color,pointer:red,marker:208,border:$border_color,header:240 \
                --bind="resize:clear-screen"
                )
            
            if [ -n "$selection" ]; then
                local i_cmd=$(echo "$selection" | cut -d'|' -f1)
                local i_sub=$(echo "$selection" | cut -d'|' -f2)
                _mux_neural_data "$i_cmd" "$i_sub"
                
                if [ $? -eq 0 ] && [ -n "$_VAL_PKG" ]; then
                    final_val="$_VAL_PKG"
                    _bot_say "success" "PKG Extracted: $final_val"
                else
                    _bot_say "warn" "No PKG binding found in node [$i_cmd $i_sub]."
                    continue
                fi
            else
                continue
            fi

        # 外部環境探測 (apklist)
        elif [ "$final_val_clean" == "[Run 'apklist']" ]; then
            echo -e "\033[1;35m :: SYSTEM APK SCANNER ::\033[0m"
            apklist
            echo -e "\n\033[1;30m(Press 'Enter' to return to Workbench...)\033[0m"
            read
            continue
        fi
        _xum_neural_write "$slot" "$col_idx" "$final_val"
        _xum_update_sts "$slot" "S"
    done
}

# 上膛解鎖 (CBR: F -> L)
function _xum_cmd_set() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi
    
    # 物理推至 L (Locked)
    _xum_update_cbr "$slot" "L"
    _bot_say "success" "CHAMBER [$slot] LOCKED (L). READY TO FIRE."
}

# 退開保險並解除鎖定 (Clear CBR & Focus)
function _xum_cmd_unset() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED."
        return 1
    fi
    
    # 洗空 CBR 狀態
    _xum_update_cbr "$slot" ""
    
    # 物理退開，解除彈巢焦點
    export XUM_CURRENT_SLOT=""
    
    _bot_say "warn" "CHAMBER [$slot] UNLOCKED. FOCUS CLEARED."
}

# 智慧排氣閥與報告銷毀機制 (Payload Purge & Report Wipe)
function _xum_cmd_clear() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -n "$slot" ]; then
        # 狀態為 Slot (Focus)：直接清空當前彈巢參數，但保留 F 狀態
        local tmp_file=$(mktemp)
        awk -v FPAT='([^,]*)|("[^"]+")' -v s="$slot" '
            BEGIN { OFS="," }
            NR == 1 { print $0; next }
            {
                row_slot = $1
                gsub(/^"|"$/, "", row_slot)
                if (row_slot == s) {
                    $3 = "\"E\""
                    for(i=4; i<=29; i++) {
                        $i = ""
                    }
                }
                print $0
            }
        ' "$XUM_DB" > "$tmp_file" && mv "$tmp_file" "$XUM_DB"
        
        _bot_say "warn" "CHAMBER [$slot] PAYLOAD PURGED."
        _xum_ui_status_panel "$slot"
    else
        # 狀態為 Unset (非 Slot)：觸發報告銷毀實體鎖
        local report_file="$MUX_ROOT/report.txt"
        echo -ne "${C_YELLOW} :: WARNING: Purge Action Report? [Y/n]: ${C_RESET}"
        read choice
        if [[ "$choice" == "y" || "$choice" == "Y" ]]; then
            rm -f "$report_file"
            touch "$report_file"
            _bot_say "success" "ACTION REPORT OBLITERATED."
        else
            echo -e "${C_BLACK}    ›› Purge aborted.${C_RESET}"
        fi
    fi
}

# 槍管擊發、戰鬥報告與退殼機制 (Fire, Report & Eject)
function _xum_cmd_fire() {
    local slot="$XUM_CURRENT_SLOT"
    if [ -z "$slot" ]; then
        _bot_say "error" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        return 1
    fi

    # 1. 讀取記憶體
    _xum_neural_read "$slot"

    # 2. 絕對物理保險：只認 CBR 為 L
    if [ "$_XUM_CBR" != "L" ]; then
        local current_cbr="${_XUM_CBR:-EMPTY}"
        _bot_say "error" "CLICK! Chamber [$slot] is not locked. CBR is [$current_cbr], requires [L]."
        return 1
    fi

    _bot_say "system" "IGNITION SEQUENCE START. DISCHARGING PAYLOAD..."

    local report_time=$(date +"%Y.%m.%d.%H:%M:%S")
    local report_file="$MUX_ROOT/report.txt"
    local report_content=""

    # 3. 判斷是否為空彈 (Dry Fire)
    local action="${_XUM_IHEAD}${_XUM_IBODY}"
    local is_empty=true
    if [ -n "$action" ] || [ -n "$_XUM_URI" ] || [ -n "$_XUM_PKG" ]; then
        is_empty=false
    fi

    if [ "$is_empty" == true ]; then
        # === 空彈擊發 ===
        echo -e "${C_GRAY}    ›› Chamber payload is empty. Testing barrel mechanism...${C_RESET}"
        report_content="-----
Time: $report_time
Playload: [EMPTY CHAMBER / DRY FIRE]
Status: Success (Test)
Output: Barrel clear. Firing mechanism nominal."
        _bot_say "success" "DRY FIRE COMPLETE."
    else
        # === 實彈射擊 (動態組裝 am 指令) ===
        local cmd="am start"
        [ -n "$_XUM_USER" ] && cmd="$cmd --user $_XUM_USER"
        [ -n "$action" ] && cmd="$cmd -a \"$action\""
        [ -n "$_XUM_URI" ] && cmd="$cmd -d \"$_XUM_URI\""
        [ -n "$_XUM_MIME" ] && cmd="$cmd -t \"$_XUM_MIME\""
        
        for cate in "$_XUM_CATE1" "$_XUM_CATE2" "$_XUM_CATE3"; do
            [ -n "$cate" ] && cmd="$cmd -c \"android.intent.category.$cate\""
        done
        [ -n "$_XUM_FLAG" ] && cmd="$cmd -f $_XUM_FLAG"

        for i in {1..5}; do
            local ex_var="_XUM_EX${i}"; local tra_var="_XUM_TRA${i}"; local boo_var="_XUM_BOO${i}"
            local ex_val="${!ex_var}"; local tra_val="${!tra_var}"; local boo_val="${!boo_var}"
            if [ -n "$ex_val" ]; then
                cmd="$cmd $ex_val"
                [ -n "$tra_val" ] && cmd="$cmd \"$tra_val\""
                [ -n "$boo_val" ] && cmd="$cmd \"$boo_val\""
            fi
        done

        # -n 與 -p 的精準物理咬合
        if [ -n "$_XUM_PKG" ]; then
            if [ -n "$_XUM_TARGET" ] && [ "$_XUM_TARGET" != "null" ] && [ "$_XUM_TARGET" != "[Empty]" ]; then
                cmd="$cmd -n \"$_XUM_PKG/$_XUM_TARGET\""
            else
                cmd="$cmd -p \"$_XUM_PKG\""
            fi
        fi

        local output
        output=$(eval "$cmd" 2>&1)

        local fire_status="Success"
        if [[ "$output" == *"Error"* ]] || [[ "$output" == *"does not exist"* ]] || [[ "$output" == *"unable to resolve"* ]]; then
            fire_status="Failure"
            _bot_say "error" "MISFIRE DETECTED."
        else
            _bot_say "success" "TARGET HIT."
        fi

        report_content="----------
Time: $report_time
Playload: $cmd
Status: $fire_status
Output: $output"
    fi

    # 4. 寫入與輸出報告
    echo "$report_content" >> "$report_file"
    echo -e "${C_TAVIOLET} :: AFTER ACTION REPORT ::${C_RESET}"
    echo "$report_content" | while read -r line; do
        if [[ "$line" == "Status: Success"* ]]; then
            echo -e "    ${C_GREEN}$line${C_RESET}"
        elif [[ "$line" == "Status: Failure" ]]; then
            echo -e "    ${C_RED}$line${C_RESET}"
        elif [[ "$line" == "----------" ]]; then
            echo -e "${C_BLACK}   $line${C_RESET}"
        else
            echo -e "    $line"
        fi
    done
    echo -e "${C_BLACK}   ----------${C_RESET}"

    # 5. 物理退殼
    local tmp_file=$(mktemp)
    awk -v FPAT='([^,]*)|("[^"]+")' -v s="$slot" '
        BEGIN { OFS="," }
        NR == 1 { print $0; next }
        {
            row_slot = $1
            gsub(/^"|"$/, "", row_slot)
            if (row_slot == s) {
                $2 = ""
                $3 = "\"E\""
                for(i=4; i<=29; i++) {
                    $i = ""
                }
            }
            print $0
        }
    ' "$XUM_DB" > "$tmp_file" && mv "$tmp_file" "$XUM_DB"
    
    export XUM_CURRENT_SLOT=""
    _bot_say "system" "CHAMBER [$slot] EJECTED & RESET."
}

# 槍管退膛與系統降壓 (Chamber Eject & System Cooldown)
function _xum_cmd_reset() {
    _bot_say "warn" "INITIATING CORE COOLDOWN SEQUENCE..."
    
    # ----------
    # [預留位置]：未來將在此處寫入 Unix 時間戳記 (2小時物理鎖)
    # ----------

    if [ -f "$XUM_DB" ]; then
        rm -f "$XUM_DB"
        echo -e "${C_BLACK}    ›› [SECURE WIPE]: Chamber database permanently destroyed.${C_RESET}"
    fi
    _bot_say "success" "TERMINATING OVERCLOCK PROTOCOL. REVERTING TO KERNEL STANDARDS."
    
    _update_mux_state "MUX" "LOGIN" "COCKPIT"
    _mux_reload_kernel
}

# 動態Help Xum選單 - Dynamic Help Overclock Detection
function _xum_dynamic_help() {
    local C_CMD="$C_TAVIOLET" 

    [ "$MUX_MODE" == "XUM" ] && head_c="$C_TAVIOLET"

    echo -e "${C_PURPLE} :: Mux-OS Core OC :: Chamber System ::${C_RESET}"
    
    awk -v c_cmd="$C_CMD" -v c_desc="\033[0;37m" -v c_reset="$C_RESET" -v c_syntax="\033[1;30m" '
        /^[ \t]*# :/ {
            desc = substr($0, match($0, /:/) + 2)
            getline
            if ($0 ~ /^[ \t]*"[a-zA-Z0-9|]+"\)/) {
                cmd = $1
                gsub(/^[ \t]*"/, "", cmd)
                gsub(/"\)$/, "", cmd)
                gsub(/\|/, ", ", cmd)
                gsub(/"/, "", cmd)
                
                printf "    %s%-9s%s %s%s%s\n", c_cmd, cmd, c_reset, c_desc, desc, c_reset
            }
        }
    ' "$OC_MOD"
}


# Mux-OS 指令入口 - Overclock Command Entry
# === Xum ===

# : Overclock Command Entry
function xum() {
    local cmd="$1"
    local arg="$2"

    if [ "$MUX_MODE" == "MUX" ]; then
        echo "bash: xum: command not found" >&2
        return 127
    fi

    if [ -z "$cmd" ]; then
        if [ -n "$XUM_CURRENT_SLOT" ]; then
            _xum_ui_status_panel "$XUM_CURRENT_SLOT"
        else
            _bot_say "warn" "NO CHAMBER FOCUSED. Execute 'xum slot <n>' first."
        fi
        return 0
    fi

    case "$cmd" in
        # : Select Ammo Chamber
        "slot")
            _xum_cmd_slot "$arg"
            ;;
            
        # : Interactive Payload
        "input")
            _xum_cmd_input
            ;;

        # : Inject Neural Link Payload
        "import")
            _xum_cmd_import "$arg" "$arg2"
            ;;
            
        # : Inject Payload parameters
        "set")
            _xum_cmd_set
            ;;
        
        # : Disarm the loaded Payload
        "unset")
            _xum_cmd_unset
            ;;
            
        # : Clear Payload or Report
        "clear")
            _xum_cmd_clear
            ;;
            
        # : Discharge the loaded Payload
        "fire")
            _xum_cmd_fire
            ;;

        # : Slot Scanner
        "check")
            _xum_cmd_check
            ;;
            
        # : Terminate Overclock
        "reset")
            _xum_cmd_reset
            ;;

        # : Open Tactical Status Panel (All Slots)
        "status"|"sts")
            _xum_ui_status_all
            ;;

        "help")
            _xum_dynamic_help
            return 0
            ;;

        *)
            echo -e "${C_YELLOW} :: Unknown Directive: '$cmd'.${C_RESET}"
            return 1
            ;;
    esac
}
